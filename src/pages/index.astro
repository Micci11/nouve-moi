---
import BaseLayout from '../layouts/BaseLayout.astro';

const featuredProducts = [
  {
    name: 'Radiance Collagen',
    image: 'https://picsum.photos/800/900?wellness&1',
    href: '/shop/radiance-collagen',
    tagline: 'Glow support from within',
  },
  {
    name: 'Daily Greens',
    image: 'https://picsum.photos/800/900?wellness&2',
    href: '/shop/daily-greens',
    tagline: 'Clean daily nourishment',
  },
  {
    name: 'Calm Elixir',
    image: 'https://picsum.photos/800/900?wellness&3',
    href: '/shop/calm-elixir',
    tagline: 'A ritual for slower evenings',
  },
  {
    name: 'Hydration+',
    image: 'https://picsum.photos/800/900?wellness&4',
    href: '/shop/hydration-plus',
    tagline: 'Electrolyte support, elevated',
  },
];

const productCategories = [
  {
    name: 'Supplements',
    href: '/shop/supplements',
    image: 'https://picsum.photos/800/600?supplements',
  },
  {
    name: 'Beauty Wellness',
    href: '/shop/beauty',
    image: 'https://picsum.photos/800/600?skincare',
  },
  {
    name: 'Sleep & Calm',
    href: '/shop/sleep',
    image: 'https://picsum.photos/800/600?sleep',
  },
  {
    name: 'Daily Essentials',
    href: '/shop/essentials',
    image: 'https://picsum.photos/800/600?wellness',
  },
];
---

<BaseLayout
title="NOÜVE · moi – Elevated Wellness"
description="Premium wellness essentials designed for your next era."
>

<!-- HERO -->
<section class="relative w-screen left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] bg-hero-bg text-gray-900 py-20 md:py-28 text-center overflow-hidden">

<!-- subtle luxury glow -->
<div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(85,198,183,0.25),transparent_60%)] pointer-events-none"></div>

<div class="relative mx-auto max-w-4xl px-4">

<p class="text-tiffany uppercase tracking-[0.4em] text-xs mb-6 font-semibold">
Elevated Wellness
</p>

<h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-bold mb-10 tracking-tight leading-tight">
NOÜVE · moi
</h1>

<p class="text-xl md:text-2xl mb-12 text-gray-700 leading-relaxed">
Refined supplements and wellness essentials for the woman becoming her next self.
</p>

<a
href="/shop"
class="bg-gray-900 text-white px-10 py-4 rounded-full font-semibold text-lg hover:bg-gray-800 transition shadow-card"
>
Shop the Collection
</a>

</div>

</section>


<!-- FEATURED PRODUCTS -->
<section class="container mx-auto px-4 py-20 max-w-7xl">

<p class="text-tiffany uppercase tracking-[0.35em] text-xs font-semibold text-center mb-4">
Our Favorites
</p>

<h2 class="text-4xl md:text-5xl font-heading font-bold text-center mb-4 text-gray-900">
Featured Products
</h2>

<div class="w-16 h-[2px] bg-tiffany mx-auto mb-14 rounded-full"></div>

<div class="grid grid-cols-1 md:grid-cols-4 gap-8">

{featuredProducts.map((product) => (

<a
href={product.href}
class="block relative rounded-2xl overflow-hidden shadow-card hover:shadow-hover transition-transform hover:scale-[1.02] duration-300 ring-1 ring-transparent hover:ring-tiffany"
>

<img
src={product.image}
alt={product.name}
class="w-full h-80 object-cover transition-transform hover:scale-105 duration-500"
/>

<div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-5 text-center">

<h3 class="text-lg font-semibold text-white">
{product.name}
</h3>

<p class="text-xs text-white/90 mt-1 tracking-wide">
{product.tagline}
</p>

</div>

</a>

))}

</div>

</section>


<!-- EMAIL -->
<section class="relative w-screen left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] bg-hero-bg py-16 md:py-20 text-center overflow-hidden">

<div class="mx-auto max-w-2xl px-8 py-10 bg-white/75 backdrop-blur-sm rounded-3xl shadow-soft">

<p class="text-tiffany uppercase tracking-[0.35em] text-xs font-semibold mb-4">
Stay Connected
</p>

<h2 class="text-3xl font-heading font-bold mb-6 text-gray-900">
Join the Inner Circle
</h2>

<p class="text-lg text-gray-700 mb-10">
Be first to know about launches, rituals, and exclusive offers.
</p>

<form class="flex flex-col md:flex-row gap-4 justify-center">

<input
type="email"
placeholder="Your email address"
class="flex-1 px-5 py-4 rounded-full border border-gray-300 focus:outline-none shadow-sm"
/>

<button
type="submit"
class="bg-gray-900 text-white px-8 py-4 rounded-full font-semibold hover:bg-gray-800 transition"
>
Subscribe
</button>

</form>

</div>

</section>


<!-- BRAND STORY -->
<section class="relative w-screen left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] bg-hero-bg py-20 overflow-hidden">

<div class="mx-auto max-w-6xl px-6">

<div class="flex flex-col md:flex-row items-center gap-16">

<div class="w-full md:w-1/2">

<img
src="https://picsum.photos/900/1100?luxury&wellness"
alt="brand aesthetic"
class="w-full rounded-3xl shadow-hover object-cover"
/>

</div>

<div class="w-full md:w-1/2 bg-white/70 backdrop-blur-sm rounded-3xl p-10 shadow-soft">

<p class="text-tiffany uppercase tracking-[0.35em] text-xs font-semibold mb-4">
Our Philosophy
</p>

<h2 class="text-4xl md:text-5xl font-heading font-bold mb-6 text-gray-900">
A New Ritual
</h2>

<p class="text-lg text-gray-700 mb-8 leading-relaxed">
NOÜVE · moi was created for women who want wellness to feel elevated,
intentional, and beautifully woven into daily life.
</p>

<a
href="/about"
class="inline-block bg-gray-900 text-white px-10 py-4 rounded-full font-semibold text-lg hover:bg-gray-800 transition"
>
Learn More
</a>

</div>

</div>

</div>

</section>


<!-- FOUNDER STRIPES -->
<section class="py-20 text-center border-t border-gray-100 bg-[repeating-linear-gradient(90deg,#ffffff,#ffffff_56px,#EAFBF7_56px,#EAFBF7_112px)]">

<div class="container mx-auto px-6 max-w-4xl bg-white/80 backdrop-blur-sm rounded-3xl p-10 md:p-14 shadow-soft">

<p class="text-tiffany uppercase tracking-[0.35em] text-xs font-semibold mb-4">
Meet the Founder
</p>

<h2 class="text-4xl md:text-5xl font-heading font-bold mb-8 text-gray-900">
About the Founder
</h2>

<p class="text-lg md:text-xl text-gray-700 mb-8 leading-relaxed">
NOÜVE · moi is rooted in the idea that wellness should support how you feel,
how you live, and how you evolve.
</p>

<a
href="/about"
class="font-medium text-lg hover:text-tiffany transition"
>
Read the Story →
</a>

</div>

</section>

</BaseLayout>