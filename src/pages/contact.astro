---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact – NOÜVE · moi"
  description="Contact the NOÜVE · moi team."
>

<!-- HERO -->
<section class="relative w-screen left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] bg-hero-bg py-24 md:py-32 text-center overflow-hidden">

  <!-- subtle glow -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(85,198,183,0.25),transparent_60%)] pointer-events-none"></div>

  <div class="relative mx-auto max-w-3xl px-6">

    <p class="text-tiffany uppercase tracking-[0.35em] text-xs font-semibold mb-5">
      Contact
    </p>

    <h1 class="text-5xl md:text-6xl font-heading font-bold mb-8 text-gray-900">
      Get in Touch
    </h1>

    <p class="text-lg md:text-xl text-gray-700 leading-relaxed">
      Questions, collaborations, or partnership inquiries —  
      we would love to hear from you.
    </p>

  </div>

</section>


<!-- CONTACT CARD -->
<section class="container mx-auto px-6 py-20 max-w-5xl">

<div class="bg-white/80 backdrop-blur-sm rounded-3xl p-10 md:p-14 shadow-soft">

<div class="grid md:grid-cols-2 gap-12">

<!-- CONTACT INFO -->
<div>

<p class="text-tiffany uppercase tracking-[0.35em] text-xs font-semibold mb-4">
Reach Us
</p>

<h2 class="text-3xl font-heading font-bold mb-6 text-gray-900">
Contact Information
</h2>

<div class="space-y-6 text-gray-700 leading-relaxed">

<p>
<strong>Email</strong><br/>
hello@nouve-moi.com
</p>

<p>
<strong>Press & Partnerships</strong><br/>
press@nouve-moi.com
</p>

<p>
<strong>Customer Care</strong><br/>
support@nouve-moi.com
</p>

</div>

</div>


<!-- CONTACT FORM -->
<div>

<p class="text-tiffany uppercase tracking-[0.35em] text-xs font-semibold mb-4">
Send a Message
</p>

<h2 class="text-3xl font-heading font-bold mb-6 text-gray-900">
We’d Love to Hear From You
</h2>

<form class="space-y-5">

<input
type="text"
placeholder="Your name"
class="w-full px-5 py-4 rounded-xl border border-gray-300 focus:outline-none"
/>

<input
type="email"
placeholder="Email address"
class="w-full px-5 py-4 rounded-xl border border-gray-300 focus:outline-none"
/>

<textarea
placeholder="Your message"
rows="4"
class="w-full px-5 py-4 rounded-xl border border-gray-300 focus:outline-none"
></textarea>

<button
type="submit"
class="bg-gray-900 text-white px-8 py-4 rounded-full font-semibold hover:bg-gray-800 transition"
>
Send Message
</button>

</form>

</div>

</div>

</div>


</section>


<!-- DIVIDER BEFORE FOOTER -->

</BaseLayout>